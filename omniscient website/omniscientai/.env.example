# Omniscient AI — Environment Variables (Template)
#
# Copy this file to .env.local for development. .env.local is gitignored.
# Production values are set per-environment in the deploy platform.

# ===== v2 Redesign Flag =====
# Controls which router mounts at production URLs.
# false = current dark-theme site (pages/)
# true  = new Bauhaus redesign (pages-v2/)
#
# During build phase, keep this false in production. In development,
# v2 is always accessible at /_v2/* regardless of this flag.
VITE_USE_V2=false
